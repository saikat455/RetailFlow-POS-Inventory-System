# ═══════════════════════════════════════════════
#  .gitignore — Place at the ROOT of your repo
#  Covers: ASP.NET Core backend + Vite/React frontend
# ═══════════════════════════════════════════════

# ── Secrets & Environment ────────────────────
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/appsettings.Development.json
**/appsettings.Production.json
**/appsettings.Staging.json

# ── .NET / Backend ───────────────────────────
**/bin/
**/obj/
**/*.user
**/*.suo
**/.vs/
**/publish/
**/out/
**/*.nupkg
**/.nuget/
**/packages/
**/TestResults/

# ── Node / Frontend ──────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
.cache/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log

# ── IDE ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini